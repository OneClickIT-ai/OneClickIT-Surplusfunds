# Vercel Postgres (auto-populated when you connect Vercel Postgres in dashboard)
POSTGRES_URL=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email provider (optional - for magic link login)
EMAIL_SERVER=
EMAIL_FROM=

# Cron job protection
CRON_SECRET=

# Admin emails (comma-separated, auto-elevated to admin role on first sign-in)
ADMIN_EMAILS=

# Dev-only fallback login. Set AUTH_DEV_MODE=true to enable the Credentials
# provider on the sign-in page. Ignored when NODE_ENV=production.
# AUTH_DEV_PASSWORD is optional — when set, it must be entered to dev-login.
AUTH_DEV_MODE=
AUTH_DEV_PASSWORD=
