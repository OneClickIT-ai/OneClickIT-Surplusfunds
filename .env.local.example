# Vercel Postgres (auto-populated when you connect Vercel Postgres in dashboard)
POSTGRES_URL=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email provider (optional - for magic link login)
EMAIL_SERVER=
EMAIL_FROM=

# Cron job protection
CRON_SECRET=

# Admin emails (comma-separated, auto-elevated to admin role on first sign-in)
ADMIN_EMAILS=

# Outbound contact providers (optional — when unset, Send SMS/Email falls
# back to a "not_configured" status log so operators still have an audit
# trail and a follow-up task is auto-scheduled).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
RESEND_API_KEY=
RESEND_FROM_ADDRESS=
